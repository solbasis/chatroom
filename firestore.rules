rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ───────────────────────────────────────────────────────────────

    // Get the calling user's full profile
    function callerProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Get the calling user's role
    function callerRole() {
      return callerProfile().role;
    }

    // Role rank map (higher = more powerful)
    function roleRank(r) {
      return r == 'dev' ? 4
           : r == 'admin' ? 3
           : r == 'mod' ? 2
           : 1; // 'user' or unknown
    }

    // True if caller has at least minRole
    function isAtLeast(minRole) {
      return roleRank(callerRole()) >= roleRank(minRole);
    }

    // True if caller is authenticated
    function authed() {
      return request.auth != null;
    }

    // FIX #5: Validate a hex color string (#rgb or #rrggbb)
    function validHex(s) {
      return s.matches('^#[0-9a-fA-F]{3}$') || s.matches('^#[0-9a-fA-F]{6}$');
    }

    // ── MESSAGES ──────────────────────────────────────────────────────────────
    match /messages/{doc} {
      allow read: if authed();

      // FIX #3: Enforce that uid in the written doc matches the authenticated uid.
      // This prevents a user from impersonating another user's messages.
      allow create: if authed()
        && !callerProfile().muted
        && request.resource.data.uid == request.auth.uid;

      // Only admin+ can soft-delete (update deleted flag)
      allow update: if authed() && isAtLeast('admin');
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if authed();

      // Creating own profile on signup — role must be 'user' (never self-grant dev/admin)
      allow create: if authed()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';

      allow update: if authed() && (

        // ① User updates their OWN safe profile fields
        (request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['bio', 'avatarUrl', 'color', 'online', 'lastSeen'])
          // FIX #5: color must be a valid hex if provided
          && (!('color' in request.resource.data.diff(resource.data).affectedKeys())
              || validHex(request.resource.data.color))
        )
        ||
        // ② User can update their own kicked/online status (for heartbeat/presence)
        (request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['online', 'lastSeen', 'kicked'])
        )
        ||
        // ③ Mods+ can mute/unmute OTHER users (not themselves)
        (request.auth.uid != userId && isAtLeast('mod')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['muted'])
        )
        ||
        // ④ Admins+ can kick, mute, set online/lastSeen on OTHER users
        (request.auth.uid != userId && isAtLeast('admin')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['muted', 'kicked', 'online', 'lastSeen'])
        )
        ||
        // ⑤ Admins+ can promote/demote roles on OTHER users, but cannot grant
        //    a role higher than their own (prevents admin granting dev)
        (request.auth.uid != userId && isAtLeast('admin')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['role'])
          // FIX #2: Can only grant up to (but not exceeding) your own role rank
          && roleRank(request.resource.data.role) < roleRank(callerRole())
        )
        ||
        // ⑥ Dev can update anything on anyone (superuser escape hatch)
        callerRole() == 'dev'
      );
    }

    // ── TYPING ────────────────────────────────────────────────────────────────
    match /typing/{userId} {
      allow read: if authed();
      // Only your own typing indicator
      allow write: if authed() && request.auth.uid == userId;
    }

    // ── BANS ──────────────────────────────────────────────────────────────────
    match /bans/{doc} {
      allow read: if authed();
      // Only admin+ can create or delete bans
      allow write: if authed() && isAtLeast('admin');
    }

    // ── DM CHANNELS ───────────────────────────────────────────────────────────
    match /dm-channels/{channelId} {

      // FIX #1: Read restricted to participants only.
      // Previously `allow read: if authed()` leaked all DM metadata to everyone.
      allow read: if authed()
        && request.auth.uid in resource.data.participants;

      // Allow create if the caller is one of the new participants
      allow create: if authed()
        && request.auth.uid in request.resource.data.participants;

      // Only participants can update channel metadata (lastMessage, lastRead, etc.)
      allow update: if authed()
        && request.auth.uid in resource.data.participants;

      // No deleting DM channels
      allow delete: if false;

      // ── DM MESSAGES SUBCOLLECTION ──────────────────────────────────────────
      match /messages/{msgId} {
        // Participants can read messages
        allow read: if authed()
          && request.auth.uid in get(/databases/$(database)/documents/dm-channels/$(channelId)).data.participants;

        // FIX #3: Participants can create messages, but uid must match caller
        allow create: if authed()
          && request.auth.uid in get(/databases/$(database)/documents/dm-channels/$(channelId)).data.participants
          && request.resource.data.uid == request.auth.uid;

        // No updating or deleting DM messages
        allow update, delete: if false;
      }
    }
  }
}
