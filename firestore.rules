rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ───────────────────────────────────────────────────────────────

    function callerProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function callerRole() {
      return callerProfile().get('role', 'user');
    }

    function roleRank(r) {
      return r == 'dev' ? 4
           : r == 'admin' ? 3
           : r == 'mod' ? 2
           : 1;
    }

    function isAtLeast(minRole) {
      return roleRank(callerRole()) >= roleRank(minRole);
    }

    function authed() {
      return request.auth != null;
    }

    function validHex(s) {
      return s.matches('^#[0-9a-fA-F]{3}$') || s.matches('^#[0-9a-fA-F]{6}$');
    }

    // ── MESSAGES ──────────────────────────────────────────────────────────────
    match /messages/{doc} {
      allow read: if authed();

      allow create: if authed() && (
        // ① Regular user/action messages — uid must match, not muted
        (
          request.resource.data.type in ['user', 'action']
          && request.resource.data.uid == request.auth.uid
          && callerProfile().get('muted', false) == false
        )
        ||
        // ② System messages (join, kick, ban announcements)
        (
          request.resource.data.type == 'system'
          && request.resource.data.keys().hasAll(['type', 'text', 'ts'])
        )
        ||
        // ③ Bot messages — only mod+ can post as 'bot-databasis' to prevent spoofing
        (
          request.resource.data.uid == 'bot-databasis'
          && request.resource.data.role == 'bot'
          && request.resource.data.type == 'user'
          && isAtLeast('mod')
        )
      );

      // Admin+ can soft-delete; any authed user can toggle reactions on non-deleted messages
      allow update: if authed() && (
        isAtLeast('admin')
        ||
        // Reactions: user can update only the reactions map on any non-deleted message
        (
          !resource.data.get('deleted', false)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        )
      );
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if authed();

      allow create: if authed()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';

      allow update: if authed() && (

        // ① User updates their OWN safe profile fields
        (request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['bio', 'avatarUrl', 'color', 'online', 'lastSeen', 'twitterHandle', 'walletAddress'])
          && (!('color' in request.resource.data.diff(resource.data).affectedKeys())
              || validHex(request.resource.data.color))
        )
        ||
        // ② User can update their own presence fields
        (request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['online', 'lastSeen'])
        )
        ||
        // ③ Mods+ can mute/unmute OTHER users
        (request.auth.uid != userId && isAtLeast('mod')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['muted'])
        )
        ||
        // ④ Admins+ can kick, mute, set online/lastSeen on OTHER users
        (request.auth.uid != userId && isAtLeast('admin')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['muted', 'kicked', 'online', 'lastSeen'])
        )
        ||
        // ⑤ Admins+ can promote/demote roles (cannot grant >= own rank)
        (request.auth.uid != userId && isAtLeast('admin')
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['role'])
          && roleRank(request.resource.data.role) < roleRank(callerRole())
        )
        ||
        // ⑥ Dev superuser
        callerRole() == 'dev'
      );
    }

    // ── TYPING ────────────────────────────────────────────────────────────────
    match /typing/{userId} {
      allow read: if authed();
      allow write: if authed() && request.auth.uid == userId;
    }

    // ── BANS ──────────────────────────────────────────────────────────────────
    match /bans/{doc} {
      allow read: if authed();
      allow write: if authed() && isAtLeast('admin');
    }

    // ── DM CHANNELS ───────────────────────────────────────────────────────────
    match /dm-channels/{channelId} {

      allow read: if authed()
        && request.auth.uid in resource.data.participants;

      allow create: if authed()
        && request.auth.uid in request.resource.data.participants;

      allow update: if authed()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if authed()
          && request.auth.uid in get(/databases/$(database)/documents/dm-channels/$(channelId)).data.participants;

        allow create: if authed()
          && request.auth.uid in get(/databases/$(database)/documents/dm-channels/$(channelId)).data.participants
          && request.resource.data.uid == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // ── BOT LOCKS (prevents duplicate bot responses from multiple clients) ───
    match /bot-locks/{lockId} {
      allow read, write: if authed();
    }

    // ── BOT STATE (tracks last-seen buy transaction for GitHub Actions) ──────
    match /bot-state/{doc} {
      allow read: if authed();
      // Only GitHub Actions (via Admin SDK) writes here — Admin SDK bypasses rules.
      // Client-side reads are allowed so the bot engine can check state.
      allow write: if false;
    }

    // ── ALERTS (dedicated buy/sell alert feed) ────────────────────────────────
    match /alerts/{doc} {
      allow read: if authed();
      // Only Admin SDK (GitHub Actions) writes alerts
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // BASIS GOV — wallet-auth governance (no Firebase Auth required)
    // Security model: wallet signatures stored in documents, on-chain balance
    // verified at the application layer. Firestore rules enforce structure.
    // ══════════════════════════════════════════════════════════════════════════

    // ── GOV: PROPOSALS ────────────────────────────────────────────────────────
    match /proposals/{proposalId} {
      // Anyone can read proposals (public governance)
      allow read: if true;

      // Create: validate required fields and sane initial values
      allow create: if
        request.resource.data.keys().hasAll([
          'title', 'description', 'author', 'endsAt',
          'status', 'yesWeight', 'noWeight', 'abstainWeight'
        ])
        && request.resource.data.title   is string
        && request.resource.data.title.size()       > 0
        && request.resource.data.title.size()       <= 120
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.status             == 'active'
        && request.resource.data.yesWeight          == 0
        && request.resource.data.noWeight           == 0
        && request.resource.data.abstainWeight      == 0;

      // Update: only vote weight increments and status finalisation allowed
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['yesWeight', 'noWeight', 'abstainWeight', 'status']);
    }

    // ── GOV: VOTES (write-once per wallet+proposal) ───────────────────────────
    match /votes/{voteId} {
      // Anyone can read vote records (public governance)
      allow read: if true;

      // Create only — no updates or deletes ever
      allow create: if
        !exists(/databases/$(database)/documents/votes/$(voteId))
        && request.resource.data.keys().hasAll([
             'proposalId', 'voter', 'choice', 'weight', 'signature'
           ])
        && request.resource.data.choice in ['yes', 'no', 'abstain']
        && request.resource.data.weight  is number
        && request.resource.data.weight  > 0
        && request.resource.data.voter   is string
        && request.resource.data.voter.size() > 0
        && request.resource.data.signature is string;

      allow update, delete: if false;
    }

    // ── GOV: STAKES ───────────────────────────────────────────────────────────
    match /stakes/{wallet} {
      // Anyone can read stake records (needed for voting weight checks)
      allow read: if true;

      // Write: validate stakedAmount is a non-negative number
      allow write: if
        request.resource.data.stakedAmount is number
        && request.resource.data.stakedAmount >= 0;
    }

    // ── GOV: CONFIG (global settings + totalStaked counter) ───────────────────
    match /config/{doc} {
      // Anyone can read config (APY, quorum settings, etc.)
      allow read: if true;

      // Allow client-side seeding on first run (create only if missing)
      allow create: if
        !exists(/databases/$(database)/documents/config/$(doc))
        && request.resource.data.keys().hasAll([
             'rewardRateAPY', 'cooldownDays', 'minProposalStake', 'quorumPercent', 'totalStaked'
           ]);

      // Allow updates to totalStaked only (stake/unstake transactions)
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalStaked'])
        && request.resource.data.totalStaked is number
        && request.resource.data.totalStaked >= 0;
    }
  }
}
